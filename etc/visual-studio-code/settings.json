{
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "github.copilot.chat.localeOverride": "ja",
    "makefile.configureOnOpen": true,
    "files.associations": {
        ".Brewfile": "ruby"
    },
    "chat.agent.maxRequests": 200,
    "chat.tools.terminal.autoApprove": {
        "flutter": true
    }
}